<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_izin_calisan" model="res.groups">
            <field name="name">İzin - Çalışan</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_izin_yonetici" model="res.groups">
            <field name="name">İzin - Yönetici</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('izin_yonetimi.group_izin_calisan'))]"/>
        </record>

        <record id="sequence_izin_talep" model="ir.sequence">
            <field name="name">İzin Talebi</field>
            <field name="code">izin.talep</field>
            <field name="prefix">IZN/%(year)s/</field>
            <field name="padding">4</field>
        </record>
    </data>
</odoo>
